# ─── App ─────────────────────────────────────────────────────
APP_NAME="Credit Risk Scoring Platform"
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database (Docker) ───────────────────────────────────────
DATABASE_URL=postgresql://creditrisk:creditrisk123@localhost:5432/creditrisk_db
ASYNC_DATABASE_URL=postgresql+asyncpg://creditrisk:creditrisk123@localhost:5432/creditrisk_db

# ─── Redis (Docker) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── ChromaDB ────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./data/mlflow
MLFLOW_EXPERIMENT_NAME=credit-risk-scoring

# ─── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_URL=https://your-grafana-instance.grafana.net
GRAFANA_API_KEY=your-grafana-api-key
